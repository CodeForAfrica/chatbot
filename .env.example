# --- sensors.africa data source (defaults work out of the box) ---
SENSORS_API_BASE=https://api.sensors.africa
# Pages of /v2/data/ to walk per query (~100 records each)
SENSORS_MAX_PAGES=3
# Cache API responses for N seconds
CACHE_TTL_SECONDS=300
# API key/token for sensors.africa (only if the API requires auth — a 403
# without it means it does). Set this as a real secret in your host's
# environment; NEVER commit the value. Leave empty for anonymous access.
SENSORS_API_KEY=
# Authorization scheme: "Token" (Django REST Framework, the default),
# "Bearer", or empty to send the raw key with no prefix.
SENSORS_API_KEY_SCHEME=Token

# --- Optional: Claude for free-form questions (leave empty to disable) ---
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-opus-4-8

# --- Optional: WhatsApp via Twilio ---
# Set to enable webhook signature verification on /whatsapp/twilio
TWILIO_AUTH_TOKEN=

# --- Optional: WhatsApp via Meta Cloud API ---
WHATSAPP_VERIFY_TOKEN=sensors-africa-bot
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
